{% extends 'base.html.twig' %}

{% block title %}ADDmeCART — {{ product.name }}{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div style="margin-bottom: 24px;">
        <a href="{{ path('app_product_catalog') }}" class="btn btn-ghost" style="padding-left: 0;">&larr; Back to Catalog</a>
    </div>

    <div style="display: flex; gap: 40px; align-items: flex-start; flex-wrap: wrap;">
        
        {# LEFT SIDE: PRODUCT DETAILS #}
        <div style="flex: 2; min-width: 350px; background: var(--surface); border-radius: var(--radius-lg); padding: 40px; box-shadow: var(--shadow-md); border: 1px solid var(--border); display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
            <div style="display: flex; justify-content: center; align-items: flex-start;">
                {% if product.thumbnailImage %}
                    <img src="{{ product.thumbnailImage }}" alt="{{ product.name }}" style="width: 100%; max-width: 500px; height: auto; object-fit: cover; border-radius: var(--radius-md); border: 1px solid var(--border);">
                {% else %}
                    <div style="width: 100%; max-width: 500px; aspect-ratio: 1/1; background: var(--bg); border-radius: var(--radius-md); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; color: var(--text-muted); font-size: 1.5rem; font-weight: 700;">No Image</div>
                {% endif %}
            </div>

            <div style="display: flex; flex-direction: column; gap: 15px;">
                <div>
                    <div style="font-size: 0.9rem; font-weight: 700; text-transform: uppercase; color: var(--primary);">{{ product.category }}</div>
                    <h1 style="font-size: 2.2rem; font-weight: 800; margin: 10px 0;">{{ product.name }}</h1>
                    <div style="color: var(--text-muted);">Sold by <strong>{{ product.seller.storeName|default('ADDmeCART') }}</strong></div>
                </div>

                <div style="font-size: 2rem; font-weight: 800;">₱{{ product.price|number_format(2) }}</div>
                
                {# Stars Display #}
                <div style="display: flex; align-items: center; gap: 10px;">
                    {% set totalStars = 0 %}
                    {% for review in product.reviews %}{% set totalStars = totalStars + review.rating %}{% endfor %}
                    {% set avgRating = product.reviews|length > 0 ? (totalStars / product.reviews|length)|round(1, 'floor') : 0 %}
                    <span style="color: #f39c12; font-size: 1.4rem;">
                        {% for i in 1..5 %}{{ i <= avgRating ? '★' : '☆' }}{% endfor %}
                    </span>
                    <span style="font-size: 0.9rem;">({{ product.reviews|length }} reviews)</span>
                </div>

                <div style="line-height: 1.6; color: var(--text-secondary);">{{ product.description }}</div>

                <div style="margin-top: auto; padding-top: 20px; border-top: 1px solid var(--border);">
                    <a href="{{ path('app_cart_add', {'id': product.id}) }}" class="btn btn-primary btn-lg" style="width: 100%; text-align: center; padding: 16px;">🛒 Add to Cart</a>
                </div>
            </div>
        </div>

        {# RIGHT SIDE: COMMENT BLOCK #}
        <div style="flex: 1; min-width: 350px; background: var(--surface); border-radius: var(--radius-lg); padding: 30px; box-shadow: var(--shadow-md); border: 1px solid var(--border);">
            <h3 style="border-bottom: 2px solid var(--border); padding-bottom: 10px; margin-bottom: 20px;">User Comments</h3>

            {# Star Filter Buttons #}
            <div style="display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 16px;">
                <button class="filter-btn active" data-filter="0" style="padding: 4px 12px; border-radius: 20px; border: 1px solid var(--border); background: var(--primary); color: #fff; cursor: pointer; font-size: 0.85rem;">All</button>
                <button class="filter-btn" data-filter="5" style="padding: 4px 12px; border-radius: 20px; border: 1px solid var(--border); background: var(--bg); cursor: pointer; font-size: 0.85rem;">★★★★★</button>
                <button class="filter-btn" data-filter="4" style="padding: 4px 12px; border-radius: 20px; border: 1px solid var(--border); background: var(--bg); cursor: pointer; font-size: 0.85rem;">★★★★</button>
                <button class="filter-btn" data-filter="3" style="padding: 4px 12px; border-radius: 20px; border: 1px solid var(--border); background: var(--bg); cursor: pointer; font-size: 0.85rem;">★★★</button>
                <button class="filter-btn" data-filter="2" style="padding: 4px 12px; border-radius: 20px; border: 1px solid var(--border); background: var(--bg); cursor: pointer; font-size: 0.85rem;">★★</button>
                <button class="filter-btn" data-filter="1" style="padding: 4px 12px; border-radius: 20px; border: 1px solid var(--border); background: var(--bg); cursor: pointer; font-size: 0.85rem;">★</button>
            </div>

            {# Reviews list #}
            <div style="max-height: 400px; overflow-y: auto; margin-bottom: 20px; position: relative;">
                {% for review in product.reviews %}
                    <div class="review-item" data-rating="{{ review.rating }}" style="border-bottom: 1px solid var(--border); padding-bottom: 15px; margin-bottom: 15px;">
                        <div style="display: flex; justify-content: space-between;">
                            <strong>{{ review.user.email }}</strong>
                            <span style="color: #f39c12;">{% for i in 1..5 %}{{ i <= review.rating ? '★' : '☆' }}{% endfor %}</span>
                        </div>
                        <p style="margin: 5px 0;">{{ review.comment }}</p>
                        <small style="color: var(--text-muted);">{{ review.createdAt|date('M d, Y') }}</small>
                    </div>
                {% else %}
                    <p class="no-reviews-msg" style="text-align: center; color: var(--text-muted);">No reviews yet.</p>
                {% endfor %}
                <p class="no-filter-results" style="display: none; text-align: center; color: var(--text-muted);">No reviews with this rating.</p>
            </div>

            {# Review form #}
            <div style="background: var(--bg); padding: 20px; border-radius: var(--radius-md); position: relative; z-index: 1;">
                <h4 style="margin-top: 0;">Write a Comment</h4>
                {% if app.user %}
                    {{ form_start(reviewForm) }}
                        {{ form_row(reviewForm.rating) }}
                        {{ form_row(reviewForm.comment) }}
                        <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 10px;">Submit Review</button>
                    {{ form_end(reviewForm) }}
                {% else %}
                    <p>Please <a href="{{ path('app_login') }}">log in</a> to leave a review.</p>
                {% endif %}
            </div>
        </div>

    </div>
</div>

<script>
    const filterBtns = document.querySelectorAll('.filter-btn');
    const reviewItems = document.querySelectorAll('.review-item');
    const noFilterMsg = document.querySelector('.no-filter-results');

    filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            const filter = parseInt(btn.dataset.filter);

            // Update active button style
            filterBtns.forEach(b => {
                b.style.background = 'var(--bg)';
                b.style.color = '';
                b.classList.remove('active');
            });
            btn.style.background = 'var(--primary)';
            btn.style.color = '#fff';
            btn.classList.add('active');

            // Show/hide reviews
            let visibleCount = 0;
            reviewItems.forEach(item => {
                const rating = parseInt(item.dataset.rating);
                const show = filter === 0 || rating === filter;
                item.style.display = show ? 'block' : 'none';
                if (show) visibleCount++;
            });

            // Show message if no reviews match
            noFilterMsg.style.display = visibleCount === 0 ? 'block' : 'none';
        });
    });
</script>

{% endblock %}