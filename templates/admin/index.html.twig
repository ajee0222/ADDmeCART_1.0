{% extends 'base.html.twig' %}

{% block title %}Admin Dashboard - ADDmeCART{% endblock %}

{% block body %}
<div style="max-width: 1000px; margin: 40px auto; padding: 20px;">
    <h1 style="color: #2c3e50; border-bottom: 2px solid #eee; padding-bottom: 10px;">Admin Dashboard: Order Management</h1>

    {# Flash messages for success notifications #}
    {% for message in app.flashes('success') %}
        <div style="background-color: #d4edda; color: #155724; padding: 12px; border-radius: 6px; margin-bottom: 20px; border: 1px solid #c3e6cb;">
            <strong>✓ Success:</strong> {{ message }}
        </div>
    {% endfor %}

    <div style="background: white; border: 1px solid #ddd; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 5px rgba(0,0,0,0.05);">
        <table style="width: 100%; border-collapse: collapse; text-align: left;">
            <thead>
                <tr style="background-color: #f8f9fa; border-bottom: 2px solid #ddd;">
                    <th style="padding: 15px; color: #333;">Order Ref</th>
                    <th style="padding: 15px; color: #333;">Date</th>
                    <th style="padding: 15px; color: #333;">Customer</th>
                    <th style="padding: 15px; color: #333;">Total</th>
                    <th style="padding: 15px; color: #333;">Update Status</th>
                </tr>
            </thead>
            <tbody>
                {% for order in orders %}
                    <tr style="border-bottom: 1px solid #eee;">
                        <td style="padding: 15px; font-weight: bold; color: #2c3e50;">
                            #{{ order.referenceNumber|default(order.id) }}
                        </td>
                        <td style="padding: 15px; color: #7f8fa6; font-size: 0.9em;">
                            {{ order.createdAt|date('M d, Y h:i A') }}
                        </td>
                        <td style="padding: 15px; color: #555;">
                            {{ order.user.email }}
                        </td>
                        <td style="padding: 15px; color: #2ecc71; font-weight: bold;">
                            ₱{{ order.totalAmount|number_format(2) }}
                        </td>
                        <td style="padding: 15px;">
                            {# The Update Form #}
                            <form action="{{ path('app_admin_update_status', {'id': order.id}) }}" method="POST" style="display: flex; gap: 10px;">
                                <select name="status" style="padding: 8px; border: 1px solid #ccc; border-radius: 4px; background: white; outline: none;">
                                    <option value="Paid via Mock API" {% if order.orderStatus == 'Paid via Mock API' %}selected{% endif %}>Paid via Mock API</option>
                                    <option value="Processing" {% if order.orderStatus == 'Processing' %}selected{% endif %}>Processing</option>
                                    <option value="Shipped" {% if order.orderStatus == 'Shipped' %}selected{% endif %}>Shipped</option>
                                    <option value="Out for Delivery" {% if order.orderStatus == 'Out for Delivery' %}selected{% endif %}>Out for Delivery</option>
                                    <option value="Completed" {% if order.orderStatus == 'Completed' %}selected{% endif %}>Completed</option>
                                    <option value="Cancelled" {% if order.orderStatus == 'Cancelled' %}selected{% endif %}>Cancelled</option>
                                </select>
                                <button type="submit" style="background: #3498db; color: white; border: none; padding: 8px 15px; border-radius: 4px; cursor: pointer; font-weight: bold;">
                                    Save
                                </button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" style="padding: 30px; text-align: center; color: #7f8fa6; font-style: italic;">
                            No orders found in the system yet.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}